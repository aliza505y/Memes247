<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ShuffleFragment">


    <TextView
        android:id="@+id/meme_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Me_irl"
        android:textColor="@color/black"
        android:textSize="@dimen/_14sdp"
        android:layout_marginTop="@dimen/_20sdp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_300sdp"
        android:layout_marginTop="@dimen/_50sdp"
        android:scaleType="centerCrop"
        android:src="@drawable/memes"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/meme_name" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView">

        <!-- Download Button -->
        <ImageButton
            android:id="@+id/btnDownload"
            android:layout_width="@dimen/_97sdp"
            android:layout_height="@dimen/_37sdp"
            android:layout_marginEnd="@dimen/_20sdp"
            android:background="@drawable/bg_red_button"
            android:src="@drawable/download"
            android:scaleType="centerInside"
            android:contentDescription="Download" />



        <!-- Refresh Button -->
        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="@dimen/_97sdp"
            android:layout_height="@dimen/_37sdp"
            android:layout_marginStart="@dimen/_20sdp"
            android:background="@drawable/bg_red_button"
            android:contentDescription="Refresh"
            android:scaleType="centerInside"
            android:src="@drawable/refresh" />

    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>